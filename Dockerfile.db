# Postgres with Home Pot migrations baked in.
# Avoids relative bind mounts which don't resolve correctly under Portainer.
FROM supabase/postgres:15.6.1.139

# zz- prefix ensures these run after the image's own /docker-entrypoint-initdb.d
# scripts (which create supabase roles).
COPY supabase/migrations/00-roles.sh    /docker-entrypoint-initdb.d/zz-00-roles.sh
COPY supabase/migrations/01-init.sql    /docker-entrypoint-initdb.d/zz-01-init.sql
COPY supabase/migrations/02-collab.sql  /docker-entrypoint-initdb.d/zz-02-collab.sql
COPY supabase/migrations/03-bank.sql    /docker-entrypoint-initdb.d/zz-03-bank.sql
COPY supabase/migrations/04-join-codes.sql /docker-entrypoint-initdb.d/zz-04-join-codes.sql
COPY supabase/migrations/05-member-admin.sql /docker-entrypoint-initdb.d/zz-05-member-admin.sql
COPY supabase/migrations/06-preserve-player-history.sql /docker-entrypoint-initdb.d/zz-06-preserve-player-history.sql
COPY supabase/migrations/07-audit-and-soft-delete.sql /docker-entrypoint-initdb.d/zz-07-audit-and-soft-delete.sql
COPY supabase/migrations/08-club-features.sql /docker-entrypoint-initdb.d/zz-08-club-features.sql
COPY supabase/migrations/09-tournament-types.sql /docker-entrypoint-initdb.d/zz-09-tournament-types.sql
COPY supabase/migrations/10-auto-advance.sql /docker-entrypoint-initdb.d/zz-10-auto-advance.sql
COPY supabase/migrations/11-admin-delete-member.sql /docker-entrypoint-initdb.d/zz-11-admin-delete-member.sql
COPY supabase/migrations/12-promote-guest.sql /docker-entrypoint-initdb.d/zz-12-promote-guest.sql
COPY supabase/migrations/13-spectator-readonly.sql /docker-entrypoint-initdb.d/zz-13-spectator-readonly.sql
COPY supabase/migrations/14-tighten-admin-rpcs.sql /docker-entrypoint-initdb.d/zz-14-tighten-admin-rpcs.sql

RUN chmod +x /docker-entrypoint-initdb.d/zz-00-roles.sh
