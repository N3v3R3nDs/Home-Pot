# Copy to .env (and .env.local for local overrides)
# These two are used by the React app at build/dev time:
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=replace-with-self-hosted-anon-key

# --- Self-hosted Supabase (used by docker-compose) ---
# Generate strong random values for production. The defaults below are demo-only.
POSTGRES_PASSWORD=home-pot-postgres-dev
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-change-me
ANON_KEY=replace-with-self-hosted-anon-key
SERVICE_ROLE_KEY=replace-with-self-hosted-service-role-key
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=home-pot-admin
SITE_URL=http://localhost:5173
